{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                u.id,\n                u.first_name,\n                u.infix,\n                u.last_name,\n                uc.role AS \"role: CommitteeRole\"\n            FROM \"user\" u\n            JOIN user_committee uc ON u.id = uc.user_id\n            WHERE uc.committee_id = $1 AND uc.\"left\" IS NULL\n            ",
